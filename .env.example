###############################################################################
# Easy!Appointments — Environment Configuration
#
# Copy this file to .env and fill in every value before running
# docker compose up -d
#
#   cp .env.example .env && nano .env
###############################################################################


# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────

# Full public URL (no trailing slash). Must match what Caddy serves.
BASE_URL=https://appointments.example.com

# Specific release tag or "latest". Pin to a tag in production, e.g. 1.5.2
EA_VERSION=latest

# Set to FALSE in production
DEBUG_MODE=FALSE

# See https://easyappointments.org/documentation/languages/ for codes
LANGUAGE=english

# Ports Caddy listens on the host
HTTP_PORT=80
HTTPS_PORT=443


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────

DB_NAME=easyappointments
DB_USERNAME=easyapp

# CHANGE THESE — use strong, unique passwords
DB_PASSWORD=CHANGE_ME_strong_app_password
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password


# ─────────────────────────────────────────────────────────────────────────────
# MAIL (SMTP)
# ─────────────────────────────────────────────────────────────────────────────

MAIL_PROTOCOL=smtp
MAIL_SMTP_HOST=smtp.example.org
MAIL_SMTP_PORT=587
MAIL_SMTP_AUTH=1
MAIL_SMTP_USER=your-smtp-username
MAIL_SMTP_PASS=your-smtp-password
# tls | ssl | none
MAIL_SMTP_CRYPTO=tls
# 0 = off, 1-4 = verbosity (keep 0 in production)
MAIL_SMTP_DEBUG=0
MAIL_FROM_ADDRESS=noreply@example.org
MAIL_FROM_NAME=Easy Appointments
MAIL_REPLY_TO_ADDRESS=support@example.org


# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE CALENDAR SYNC (optional)
# ─────────────────────────────────────────────────────────────────────────────

GOOGLE_SYNC_FEATURE=FALSE
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
# CADDY / TLS
#
# Caddy obtains and renews TLS certificates automatically via Let's Encrypt.
# No separate certbot setup is required.
#
# DOMAIN      — public hostname Caddy will serve and request a certificate for.
#               Use "localhost" for local-only or when TLS is terminated upstream.
# ACME_EMAIL  — contact email for Let's Encrypt registration and expiry notices.
# ─────────────────────────────────────────────────────────────────────────────

DOMAIN=appointments.example.com
ACME_EMAIL=admin@example.com


# ─────────────────────────────────────────────────────────────────────────────
# BACKUPS
# ─────────────────────────────────────────────────────────────────────────────

# How many backup files to keep
BACKUP_RETENTION_DAYS=14

# Cron expression — default: 2:00 AM every day
BACKUP_CRON=0 2 * * *
