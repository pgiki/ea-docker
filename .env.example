###############################################################################
# Easy!Appointments — Environment Configuration
#
# Copy this file to .env and fill in every value before running
# docker compose up -d
#
#   cp .env.example .env && nano .env
###############################################################################


# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────

# Full public URL (no trailing slash). Must match what Caddy serves.
BASE_URL=https://appointments.example.com

# Specific release tag or "latest". Pin to a tag in production, e.g. 1.5.2
EA_VERSION=latest

# Set to FALSE in production
DEBUG_MODE=FALSE

# Folder name under application/language/ — NOT a locale (use english, not en_US or en-US).
# Named EA_LANGUAGE because Linux sets a GNU LANGUAGE=en_US:… locale var that breaks docker compose.
# See https://easyappointments.org/documentation/languages/
EA_LANGUAGE=english

# ── Reverse proxy mode ───────────────────────────────────────────────────────
#
# EXTERNAL (default) — another Caddy already uses 80/443 on this host.
#   Leave COMPOSE_PROFILES empty. App binds to APP_UPSTREAM_* below.
#   Add a site block from caddy/external-proxy.Caddyfile.example to your main Caddy.
#
# BUILTIN — this stack runs its own Caddy (needs free 80/443 on the host).
#   COMPOSE_PROFILES=builtin-caddy
#   HTTP_PORT=80
#   HTTPS_PORT=443
#
COMPOSE_PROFILES=

# Where your main Caddy reverse_proxies to (external mode only)
APP_UPSTREAM_BIND=127.0.0.1
APP_UPSTREAM_PORT=8086

# install.sh writes /etc/caddy/sites/<DOMAIN>.caddy on the host (requires sudo)
CADDY_SITES_DIR=/etc/caddy/sites

# Only used with COMPOSE_PROFILES=builtin-caddy
HTTP_PORT=80
HTTPS_PORT=443


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────

DB_NAME=easyappointments
DB_USERNAME=easyapp

# CHANGE THESE — use strong, unique passwords
DB_PASSWORD=CHANGE_ME_strong_app_password
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password


# ─────────────────────────────────────────────────────────────────────────────
# MAIL (SMTP)
# ─────────────────────────────────────────────────────────────────────────────

MAIL_PROTOCOL=smtp
MAIL_SMTP_HOST=smtp.example.org
MAIL_SMTP_PORT=587
MAIL_SMTP_AUTH=1
MAIL_SMTP_USER=your-smtp-username
MAIL_SMTP_PASS=your-smtp-password
# tls | ssl | none
MAIL_SMTP_CRYPTO=tls
# 0 = off, 1-4 = verbosity (keep 0 in production)
MAIL_SMTP_DEBUG=0
MAIL_FROM_ADDRESS=noreply@example.org
MAIL_FROM_NAME=Easy Appointments
MAIL_REPLY_TO_ADDRESS=support@example.org


# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE CALENDAR SYNC (optional)
# ─────────────────────────────────────────────────────────────────────────────

GOOGLE_SYNC_FEATURE=FALSE
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
# DOMAIN / TLS
#
# DOMAIN     — public hostname (must match BASE_URL and your main Caddy site block).
# ACME_EMAIL — only used when COMPOSE_PROFILES=builtin-caddy (Let's Encrypt in this stack).
# ─────────────────────────────────────────────────────────────────────────────

DOMAIN=appointments.example.com
ACME_EMAIL=admin@example.com


# ─────────────────────────────────────────────────────────────────────────────
# BACKUPS
# ─────────────────────────────────────────────────────────────────────────────

# How many backup files to keep
BACKUP_RETENTION_DAYS=14

# Cron expression — default: 2:00 AM every day (must be quoted; spaces break unquoted values)
BACKUP_CRON="0 2 * * *"
