# mysql/conf.d/production.cnf
# MySQL 8.0 tuning for Easy!Appointments production use.
# Adjust innodb_buffer_pool_size to ~70% of available RAM on a dedicated DB host.

[mysqld]

# ── Character set ─────────────────────────────────────────────────────────────
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# ── InnoDB ────────────────────────────────────────────────────────────────────
innodb_buffer_pool_size        = 256M   # raise to ~70% RAM on dedicated host
innodb_buffer_pool_instances   = 1
innodb_log_file_size           = 64M
innodb_flush_log_at_trx_commit = 1      # ACID-safe (keep 1 in production)
innodb_flush_method            = O_DIRECT

# ── Connections ───────────────────────────────────────────────────────────────
max_connections      = 100
wait_timeout         = 300
interactive_timeout  = 300
connect_timeout      = 10

# ── Query cache (disabled in MySQL 8) ────────────────────────────────────────
# query_cache_type  = 0

# ── Slow query log ────────────────────────────────────────────────────────────
slow_query_log       = 1
slow_query_log_file  = /var/lib/mysql/slow.log
long_query_time      = 2

# ── Binlog (enables point-in-time recovery) ───────────────────────────────────
log_bin                 = /var/lib/mysql/mysql-bin
binlog_expire_logs_seconds = 604800   # 7 days
max_binlog_size         = 100M
binlog_format           = ROW

# ── Misc ──────────────────────────────────────────────────────────────────────
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
